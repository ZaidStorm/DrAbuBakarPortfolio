# .env.example — copy this to .env for local development (never commit .env)
# On Vercel: add these under Settings -> Environment Variables

# ─── REQUIRED ────────────────────────────────────────────────────────────────
# Paste the FULL contents of your service-account JSON file as a single value.
# On Vercel, paste the JSON as-is (multi-line is fine in the UI).
# No Base64 encoding needed.
GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n","client_email":"portfolio-drive-reader@....iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}

# ─── OPTIONAL (skips the Drive search on every cold start) ───────────────────
# Get this from the URL when you open your AbuBakar-Portfolio folder in Drive:
# https://drive.google.com/drive/folders/THIS_IS_THE_ID
PORTFOLIO_ROOT_FOLDER_ID=
