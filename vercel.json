{
  "version": 2,
  "headers": [
    {
      "source": "/api/stream/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, s-maxage=3600, stale-while-revalidate=600" },
        { "key": "Accept-Ranges",  "value": "bytes" }
      ]
    },
    {
      "source": "/api/portfolio",
      "headers": [
        { "key": "Cache-Control", "value": "s-maxage=600, stale-while-revalidate=60" }
      ]
    },
    {
      "source": "/api/portfolio/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "s-maxage=600, stale-while-revalidate=60" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" }
  ]
}
